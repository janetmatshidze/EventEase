@{
    ViewData["Title"] = "Create Venue";
}

@model EventEase.Models.Venue

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
<link href="~/css/site.css" rel="stylesheet" />
<div class="container my-5">
    <div class="card shadow-lg border-0">
        <div class="card-header text-center bg-dark text-white">
            <h2 class="mb-0">Create New Venue</h2>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" novalidate>
                <div class="mb-3">
                    <label asp-for="VenueName" class="form-label fw-bold">Venue Name</label>
                    <input asp-for="VenueName" class="form-control" placeholder="Enter venue name" required />
                    <span asp-validation-for="VenueName" class="text-danger" style="display:none;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Location" class="form-label fw-bold">Location</label>
                    <input asp-for="Location" class="form-control" placeholder="Enter venue location" required />
                    <span asp-validation-for="Location" class="text-danger" style="display:none;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Capacity" class="form-label fw-bold">Capacity</label>
                    <input asp-for="Capacity" class="form-control" type="number" placeholder="Enter venue capacity" required />
                    <span asp-validation-for="Capacity" class="text-danger" style="display:none;"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ImageUrl" class="form-label fw-bold">Venue Image URL</label>
                    <input asp-for="ImageUrl" class="form-control" placeholder="Enter Image URL" required />
                    <span asp-validation-for="ImageUrl" class="text-danger" style="display:none;"></span>
                </div>

                <div class="d-flex justify-content-center gap-3 mt-4">
                    <button type="submit" class="btn custom-btn btn-lg px-5 shadow w-25">Create Venue</button>
                    <a asp-action="Index" class="btn btn-secondary btn-compact btn-lg px-5 shadow w-25">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        document.querySelector("form").addEventListener("submit", function(event) {
            let inputs = document.querySelectorAll(".form-control");
            let valid = true;
            inputs.forEach(input => {
                let errorSpan = input.nextElementSibling;
                if (input.value.trim() === "") {
                    errorSpan.style.display = "block";
                    valid = false;
                } else {
                    errorSpan.style.display = "none";
                }
            });
            if (!valid) {
                event.preventDefault();
            }
        });
    </script>
}
